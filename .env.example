# Hunter.io — free tier: 25 searches/month
# Sign up at https://hunter.io/users/sign_up
HUNTER_API_KEY=

# Tavily — free tier: 1000 searches/month
# Sign up at https://tavily.com
TAVILY_API_KEY=

# Groq — free tier: generous rate limits
# Sign up at https://console.groq.com
GROQ_API_KEY=

# Gmail SMTP — use an App Password, NOT your real password
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an app password for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_APP_PASSWORD=

# Dashboard URL (for CORS in production)
DASHBOARD_URL=http://localhost:3000
